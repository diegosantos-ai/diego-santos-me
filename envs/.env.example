# ==============================================================================
# BASE DA APLICAÇÃO
# ==============================================================================
APP_BASE_URL=http://localhost:3000
APP_LOG_LEVEL=info
APP_ENABLE_DEBUG=true
APP_HEALTHCHECK_PATH=/health
INTERNAL_API_URL=http://localhost:8001/api/v1

# ==============================================================================
# INFRA E JVM TUNING
# ==============================================================================
JAVA_OPTS="-Xms256m -Xmx256m"

# ==============================================================================
# BANCO DE DADOS (PostgreSQL)
# ==============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=portfolio_dev
DB_USER=portfolio_user
DB_PASSWORD=portfolio_secret

# ==============================================================================
# LEARNING IN PUBLIC (PORTFOLIO-API-JAVA)
# ==============================================================================
LEARNING_ENABLED=true
LEARNING_REPOSITORIES=diegosantos-ai/dev-workspace,diegosantos-ai/diego-santos-me
LEARNING_CRON_SCHEDULE="0 */15 * * * *"
LEARNING_AUTO_PUBLISH=false
LEARNING_MAX_ITEMS_PER_RUN=10

# ==============================================================================
# INTEGRAÇÕES / SEGREDOS
# ==============================================================================
GITHUB_TOKEN=ghp_your_token_here
LLM_API_KEY=sk-your_api_key_here
